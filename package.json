{
  "name": "discord-server-events-feed",
  "version": "1.1.0",
  "description": "A simple utility to generate an ICS file for scheduled events in a Discord server.",
  "keywords": [
    "calendar",
    "discord",
    "discord-bot",
    "ics",
    "javascript",
    "nodejs"
  ],
  "homepage": "https://github.com/seriouslysean/discord-server-events-feed#readme",
  "bugs": {
    "url": "https://github.com/seriouslysean/discord-server-events-feed/issues"
  },
  "license": "MIT",
  "author": "Sean Kennedy <sean@codeserious.com>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/seriouslysean/discord-server-events-feed.git"
  },
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file-if-exists=.env --import tsx ./src/index.ts",
    "generate:feed": "tsx ./src/index.ts",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
